generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────────

enum Role {
  MASTER
  PLAYER
}

enum BaseRank {
  E
  D
  C
  B
  A
  S
}

enum RacePath {
  ASCENSAO
  CORRUPCAO
  PERMANENCIA
}

enum SpecialCardType {
  VALETE
  CAVALEIRO
}

enum ReadingType {
  COMUM
  PROFUNDA
}

// ─── AUTH ─────────────────────────────────────────────────

model User {
  id           String           @id @default(cuid())
  email        String           @unique
  username     String?
  avatar       String?
  bio          String?
  createdAt    DateTime         @default(now())
  passwordHash String?
  accounts     Account[]
  sessions     Session[]
  memberships  CampaignMember[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── CAMPANHA ─────────────────────────────────────────────

model Campaign {
  id          String           @id @default(cuid())
  name        String
  description String?
  inviteCode  String           @unique @default(cuid())
  masterId    String
  createdAt   DateTime         @default(now())
  members     CampaignMember[]
  worlds      World[]
  characters  Character[]
  items       InventoryItem[]
}

model CampaignMember {
  id         String   @id @default(cuid())
  userId     String
  campaignId String
  role       Role     @default(PLAYER)
  active     Boolean  @default(false)
  joinedAt   DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([userId, campaignId])
}

// ─── MUNDO ────────────────────────────────────────────────

model World {
  id          String    @id @default(cuid())
  slug        String
  name        String
  description String?
  coverColor  String?
  coverImage  String?
  isLocked    Boolean   @default(true)
  campaignId  String
  campaign    Campaign  @relation(fields: [campaignId], references: [id])
  chapters    Chapter[]

  @@unique([slug, campaignId])
}

model Chapter {
  id      String @id @default(cuid())
  title   String
  content String @db.Text
  order   Int
  worldId String
  world   World  @relation(fields: [worldId], references: [id])
}

// ─── UNIVERSO / RAÇA ──────────────────────────────────────

model Universe {
  id     String          @id @default(cuid())
  name   String          @unique
  worlds UniverseWorld[]
}

model UniverseWorld {
  id         String    @id @default(cuid())
  name       String
  universeId String
  universe   Universe  @relation(fields: [universeId], references: [id])
  races      Race[]

  @@unique([name, universeId])
}

model Race {
  id              String          @id @default(cuid())
  name            String
  element         String
  baseRank        BaseRank        @default(D)
  canAscend       Boolean         @default(false)
  canCorrupt      Boolean         @default(false)
  universeWorldId String
  universeWorld   UniverseWorld   @relation(fields: [universeWorldId], references: [id])
  characters      Character[]
  skills          RaceSkill[]
  evolutions      RaceEvolution[] @relation("FromRace")

  @@unique([name, universeWorldId])
}

// habilidades inatas de cada raça
model RaceSkill {
  id            String  @id @default(cuid())
  raceId        String
  race          Race    @relation(fields: [raceId], references: [id])
  name          String
  description   String  @db.Text
  branch        String  // passiva | aprimoramento | ativa | reacao
  levelRequired Int     @default(1)
  isInnate      Boolean @default(true)
}

// para qual raça cada caminho de evolução leva
model RaceEvolution {
  id            String   @id @default(cuid())
  fromRaceId    String
  fromRace      Race     @relation("FromRace", fields: [fromRaceId], references: [id])
  toRaceName    String
  path          RacePath
  levelRequired Int      @default(100)
}

// ─── PERSONAGEM ───────────────────────────────────────────

model Character {
  id          String  @id @default(cuid())
  name        String
  category    String  // aluno | professor | npc | monstro
  element     String
  image       String?
  worldSlug   String
  isLocked    Boolean @default(false)
  campaignId  String
  playerId    String?

  // campos específicos por categoria (nullable)
  year        Int?    // aluno
  subject     String? // professor
  occupation  String? // npc
  dangerLevel String? // monstro

  // progressão
  level Int @default(1)
  xp    Int @default(0)
  maxXp Int @default(100)

  // rank de nascença (vem da raça, nunca muda)
  // rank atual é calculado pelo level no código — não salvo no banco
  birthRank BaseRank @default(D)

  // caminho de evolução da raça (preenchido quando o jogador escolhe)
  racePath      RacePath? // null = ainda não escolheu
  evolvedRaceId String?

  // atributos (escala por rank: D 1–10 | C 4–45 | B 6–63 | A 8–81 | S 10–100)
  agilidade    Int @default(1)
  inteligencia Int @default(1)
  forca        Int @default(1)
  vigor        Int @default(1)
  sorte        Int @default(1)

  // PV = 10 + (vigor × 2) | PM = 10 + (inteligencia × 2) — cacheados
  pv    Int @default(12)
  pvMax Int @default(12)
  pm    Int @default(12)
  pmMax Int @default(12)

  // relações
  raceId       String
  race         Race          @relation(fields: [raceId], references: [id])
  campaign     Campaign      @relation(fields: [campaignId], references: [id])
  skills       Skill[]
  tarotDraws   TarotDraw[]
  specialCards SpecialCard[]

  conditions   CharacterCondition[]
}

model CharacterCondition {
  id          String    @id @default(cuid())
  characterId String
  type        String    // "envenenado" | "exausto" | etc.
  appliedAt   DateTime  @default(now())
  removedAt   DateTime?
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
}

// ─── HABILIDADES ──────────────────────────────────────────

model Skill {
  id                     String    @id @default(cuid())
  name                   String
  description            String
  branch                 String    // ativa | passiva | reacao | aprimoramento
  element                String
  currentLevel           Int       @default(0)
  maxLevel               Int       @default(3)
  isUnlocked             Boolean   @default(false)
  requiredCharacterLevel Int
  uses     Int @default(0) 
  characterId            String
  character              Character @relation(fields: [characterId], references: [id])
}

// ─── CARTAS ESPECIAIS ─────────────────────────────────────

model SpecialCard {
  id          String          @id @default(cuid())
  characterId String
  cardType    SpecialCardType
  isAvailable Boolean         @default(true)
  obtainedAt  DateTime        @default(now())
  usedAt      DateTime?
  character   Character       @relation(fields: [characterId], references: [id], onDelete: Cascade)
  // unicidade garantida via Server Action, não aqui
}

// ─── LEITURAS DE TARÔ ─────────────────────────────────────

model TarotDraw {
  id                   String      @id @default(cuid())
  readingType          ReadingType
  question             String      @db.Text
  cards                String[]
  sacrifice            String      @db.Text  @default("")
  sacrificeIsPermanent Boolean     @default(false)
  hadJoker             Boolean     @default(false)
  drawnAt              DateTime    @default(now())
  characterId          String
  character            Character   @relation(fields: [characterId], references: [id], onDelete: Cascade)

  // ── campos para o fluxo de leitura em tempo real ──
  status               String      @default("pendente") // pendente | cartas_reveladas | concluida
  initiatedByMasterId  String?     // id do mestre que iniciou
}

// ─── INVENTÁRIO ───────────────────────────────────────────

model InventoryItem {
  id         String        @id @default(cuid())
  name       String
  slug       String
  category   String        // equipamento | consumivel | material | reliquia | livro | outro
  rarity     String
  quantity   Int           @default(1)
  image      String?
  worldSlug  String?
  isLocked   Boolean       @default(false)
  campaignId String
  ownerId    String?

  // campos específicos por tipo (nullable)
  forgedBy   String? // equipamento
  effect     String? // equipamento | consumivel | reliquia
  origin     String? // consumivel | material | reliquia | outro
  author     String? // livro
  coverType  String? // livro: color | image
  coverColor String? // livro
  coverImage String? // livro

  campaign Campaign      @relation(fields: [campaignId], references: [id])
  chapters ItemChapter[]

  @@unique([slug, campaignId])
}

model ItemChapter {
  id      String        @id @default(cuid())
  title   String
  content String        @db.Text
  order   Int
  itemId  String
  item    InventoryItem @relation(fields: [itemId], references: [id])
}